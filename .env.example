# ─────────────────────────────────────────────────────────────
# Cấu hình SATORI v2 — copy file này thành .env và sửa cho phù hợp
# ─────────────────────────────────────────────────────────────

# Database
# Dev (tại nhà) dùng SQLite, không cần cài gì:
DATABASE_URL=sqlite:///./data/satori.db
# Prod (tại site) dùng PostgreSQL:
# DATABASE_URL=postgresql://postgres:matkhau@localhost:5432/satori

# Chế độ thiết bị: true = mock (tại nhà), false = thật (tại site)
USE_MOCK_DEVICES=true

# ── Scanner ──
# Hỗ trợ NHIỀU scanner: liệt kê host:port cách nhau bởi dấu phẩy.
# VD 3 scanner: 192.168.1.40:51236,192.168.1.41:51236,192.168.1.42:51236
SCANNER_HOSTS=192.168.1.40:51236

# ── IO-Box (ModBus TCP) ──
IOBOX_HOST=192.168.1.50
IOBOX_PORT=502

# ── Laser printer (TCP) ──
LASER_HOST=192.168.1.60
LASER_PORT=9100

# Web server
WEB_HOST=0.0.0.0
WEB_PORT=8000

# Mật khẩu admin mặc định (đổi sau)
ADMIN_PASSWORD=stradmin
